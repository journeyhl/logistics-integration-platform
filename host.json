{
  "version": "2.0",
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "logging": {
    "logLevel": {
      "default": "Information",
      "Microsoft.AspNetCore": "None",
      "Microsoft.Azure.WebJobs.Script.Description": "None",
      "Microsoft.Azure.WebJobs.Script.WebHost": "None",
      "Microsoft.Azure.WebJobs.Script.WebHost.Security": "None",
      "Microsoft.Azure.WebJobs.Script.WebHost.Management": "None",
      "Microsoft.Azure.WebJobs.Host": "None",
      "Microsoft.Azure.WebJobs.Host.Executors": "None",
      "Microsoft.Azure.WebJobs.Script": "Information",
      "Host.Aggregator": "Information",
      "Host.Results": "Warning",
      "Host.Executor": "Warning",
      "Function": "Warning"
   
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true
      }
    }
  }
}